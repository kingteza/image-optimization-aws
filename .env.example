# Image Optimization — environment variables
# Copy to .env and adjust values: cp .env.example .env
#
# Used when running: npm run build && cdk deploy
# CDK CLI flags (-c KEY=value) override these values if both are set.

# --- AWS (optional if using `aws configure` or IAM role) ---
# AWS_REGION=us-east-1
# CDK_DEFAULT_REGION=us-east-1
# AWS_ACCOUNT_ID=

# --- CDK stack parameters (all optional; defaults shown) ---

# Originals bucket for this stack (Lambda reads from here).
# Leave empty: CDK creates a NEW bucket (+ sample images under images/rio/).
# Set a name: use an existing bucket you created (CDK does not modify your other CloudFront).
# Legacy slre-default + domain CloudFront can stay unchanged; upload new images to the bucket from deploy output.
# S3_IMAGE_BUCKET_NAME=

# Store transformed images in S3 (true) or transform on every cache miss (false).
STORE_TRANSFORMED_IMAGES=true

# Days until transformed S3 objects expire (when STORE_TRANSFORMED_IMAGES=true).
S3_TRANSFORMED_IMAGE_EXPIRATION_DURATION=90

# Cache-Control header on transformed images (quote values containing =).
S3_TRANSFORMED_IMAGE_CACHE_TTL='max-age=31622400'

# CloudFront Origin Shield region (unset = auto from stack region).
# CLOUDFRONT_ORIGIN_SHIELD_REGION=us-east-1

# Allow CORS on the image delivery distribution.
CLOUDFRONT_CORS_ENABLED=true

# Lambda image-processing function settings.
LAMBDA_MEMORY=1500
LAMBDA_TIMEOUT=60

# Max transformed image size in bytes.
MAX_IMAGE_SIZE=4700000

# Deploy sample static website CloudFront + S3 (true/false).
DEPLOY_SAMPLE_WEBSITE=false
